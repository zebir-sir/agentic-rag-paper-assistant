# API Configuration
APP_ENV=development
LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8888
API_URL=http://api:8888

# Streamlit Configuration
SERVER_PORT=8501
SERVER_HOST=0.0.0.0

# POSTGRES VECTOR DB CONFIGURATION
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=postgres
DB_PORT=5432
DB_NAME=vector_db

# OpenAI API Configuration
OPENAI_API_KEY=your_api_key
OPENAI_BASE_URL=your_base_url
LLM_CHOICE=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# OpenAlex Configuration
OPENALEX_API_KEY=your_openalex_key
OPENALEX_MAILTO=you@example.com

# General web search is optional.
# It is used for general technical/web questions, not OpenAlex paper discovery.
# If these variables are not configured, the system still works and search_web returns empty results.
# OpenAlex and general web search are two separate tools.
GENERAL_WEB_SEARCH_ENABLED=false
GENERAL_WEB_SEARCH_PROVIDER=custom
GENERAL_WEB_SEARCH_API_KEY=your-web-search-key
GENERAL_WEB_SEARCH_ENDPOINT=https://example.com/search

# Agent backend selection
AGENT_BACKEND=langchain
STREAM_BACKEND=langchain
